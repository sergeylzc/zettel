<meta charset="UTF-8">
<link
  rel="apple-touch-icon"
  sizes="180x180"
  href="/apple-touch-icon.png">
<link
  rel="icon"
  type="image/png"
  sizes="32x32"
  href="/favicon-32x32.png">
<link
  rel="icon"
  type="image/png"
  sizes="16x16"
  href="/favicon-16x16.png">
{%- assign description = excerpt | default: siteMeta.desc -%}

<meta name="viewport" content="width=device-width, initial-scale=1">

{% if title == undefined or title == "" %}
  <title>小隧道卡片盒</title>
  <meta name="twitter:title" content="小隧道卡片盒">
  <meta property="og:title" content="小隧道卡片盒">
{% else %}
  <title>{{ title }} - 小隧道卡片盒</title>
  <meta name="twitter:title" content="{{ title }} - 小隧道卡片盒">
  <meta property="og:title" content="{{ title }} - 小隧道卡片盒">
{% endif %}


<meta name="description" content="{{ description }}">
<meta name="twitter:description" content="{{ description }}">

<meta property="og:locale" content="zh_cn">
<meta property="og:site_name" content="小隧道卡片盒">
<meta property="og:type" content="website">
<meta name="twitter:card" content="summary">
<meta name="twitter:domain" content="小隧道卡片盒">
<meta name="twitter:site" content="@sergeylzc">

{%- if canonical_link -%}
  <link rel="canonical" href="{{canonical_link}}" />
{%- endif -%}

{%- if featured_img -%}
  <meta property="og:image" content="{{ featured_img }}">
  <meta name="twitter:image" content="{{ featured_img }}">
{%- endif -%}