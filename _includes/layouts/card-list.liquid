---
layout: _html
---
{%- render "partials/header", collectionsAll: collections.all, page: page -%}
<main class="container max-w-screen-xl mx-auto px-4">
  <div class="aside-nav hidden fixed lg:block">
    {%- render "partials/aside-nav", collectionsAll: collections.all, page: page -%}
  </div>
  <div class="card-list lg:pl-[19.5rem]">
    {%- for card in collections[collectionKey] -%}
      <div class="card" id="{{ card.fileSlug }}">
        <h2>{{ card.data.title }}</h2>
        {{ card.templateContent }}
        <a href="{{ card.url }}">查看更多</a>
      </div>
    {%- endfor -%}
  </div>
</main>